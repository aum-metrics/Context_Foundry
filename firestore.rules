rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Get user data from users collection
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Check if user belongs to an organization
    function belongsToOrg(orgId) {
      return isSignedIn() && getUserData().orgId == orgId;
    }

    // Users collection: User can only read/write their own document
    match /users/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // Organizations and their subcollections
    match /organizations/{orgId} {
      // Basic org info access - 🛡️ Hardened to prevent reading apiKeys
      allow read: if belongsToOrg(orgId) && !('apiKeys' in resource.data);
      
      // Admin might need to update org settings
      allow write: if belongsToOrg(orgId) && getUserData().role == 'admin';

      // Jobs and Manifests: Any org member can read/write (needed for FE interaction)
      // Jobs and Manifests: Backend/System only for mutations
      match /batchJobs/{jobId} { allow read: if belongsToOrg(orgId); allow write: if false; }
      match /seoJobs/{jobId} { allow read: if belongsToOrg(orgId); allow write: if false; }
      match /manifests/{docId} { allow read: if belongsToOrg(orgId); allow write: if false; }

      // Sensitive Subcollections: Read-only for ADMINS, No write except via backend
      match /api_keys/{key} { allow read: if belongsToOrg(orgId) && getUserData().role == 'admin'; allow write: if false; }
      match /payments/{pay} { allow read: if belongsToOrg(orgId) && getUserData().role == 'admin'; allow write: if false; }
      match /auditLogs/{log} { allow read: if belongsToOrg(orgId) && getUserData().role == 'admin'; allow write: if false; }
      match /pendingInvites/{inv} { allow read: if belongsToOrg(orgId); allow write: if false; }
      match /scoringHistory/{hist} { allow read: if belongsToOrg(orgId); allow write: if false; }
    }

    // Leads/Contact Funnel: Allow public write (P1 Fix), Admin only read
    match /leads/{leadId} {
      allow create: if true;
      allow read: if isSignedIn() && getUserData().role == 'admin';
      allow update, delete: if false;
    }

    // Public Assets
    match /public/{doc=**} {
      allow read: if true;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}