rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 🛡️ ZERO-DAY HARDENING: Strict least-privilege security rules
    
    // Helper: is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper: is owner of organization
    function isOrgMember(orgId) {
      return isAuthenticated() && exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid));
    }

    // Organizations: Public read of basic info (for whitelabeling), but strict writes
    match /organizations/{orgId} {
      allow read: if true;
      allow write: if false; // Admin SDK only
      
      // Members sub-collection
      match /members/{userId} {
        allow read: if request.auth.uid == userId || isOrgMember(orgId);
        allow write: if false; // Admin SDK only
      }
      
      // Manifests
      match /manifests/{docId} {
        allow read: if isOrgMember(orgId);
        allow write: if false; // Admin SDK only
      }
      
      // Simulations & Billing
      match /simulations/{docId} {
        allow read: if isOrgMember(orgId);
        allow write: if false; // Admin SDK only
      }
    }
    
    // Users profile
    match /users/{userId} {
      allow read: if request.auth.uid == userId;
      allow write: if request.auth.uid == userId; // Basic profile updates
    }
    
    // Public Leads / Contact
    match /leads/{leadId} {
      allow create: if true; // Public contact form
      allow read, update, delete: if false; // Admin only
    }

    // Default: Deny all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}